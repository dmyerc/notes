* ------------------------------------------------------------------------------
* 
* Title:    INFINEON Power Transistors Simulation Models for PSpice
* Description: p-channel Transistors
*                 OptiMOS-P2 40V
* Authors:  Dr. Elmar Gondro, Tel: +49/89/234-29391
*           Sebastian Koch,   Tel: +49/89/234-89858
*           Gerhard Nöbauer,  Tel: +43/(5)/1777-6653
* Email:    Elmar.Gondro@Infineon.com
*           Sebastian.Koch@Infineon.com
*           Gerhard.Noebauer@Infineon.com
* Support:  Support@Infineon.com
*           www.Infineon.com/support
*
* ------------------------------------------------------------------------------
* 
* This library contains models of the following INFINEON transistors:
* 
* Product          DeviceType  Level  VDSmax/V  RDSonmax/mOhm  IDmax/A  Package            L3-ModelName       L1-ModelName         L0-ModelName 
* -----------------------------------------------------------------------------------------------------------------------------------------------------
* IPB120P04P4L-03    OptiMOS      LL      -40        3.1       -120     TO263-3.(D2PAK)    IPB120P04P4L_03    IPB120P04P4L_03_L1   IPB120P04P4L_03_L0  
* IPB180P04P4L-02    OptiMOS      LL      -40        2.4       -180     TO263-7.(D2PAK)    IPB180P04P4L_02    IPB180P04P4L_02_L1   IPB180P04P4L_02_L0  
* IPB80P04P4L-04     OptiMOS      LL      -40        4.4        -80     TO263-3.(D2PAK)    IPB80P04P4L_04     IPB80P04P4L_04_L1    IPB80P04P4L_04_L0   
* IPB80P04P4L-06     OptiMOS      LL      -40        6.4        -80     TO263-3.(D2PAK)    IPB80P04P4L_06     IPB80P04P4L_06_L1    IPB80P04P4L_06_L0   
* IPB80P04P4L-08     OptiMOS      LL      -40        7.9        -80     TO263-3.(D2PAK)    IPB80P04P4L_08     IPB80P04P4L_08_L1    IPB80P04P4L_08_L0   
* IPD50P04P4L-11     OptiMOS      LL      -40       10.6        -50     TO252-3.(DPAK)     IPD50P04P4L_11     IPD50P04P4L_11_L1    IPD50P04P4L_11_L0   
* IPD70P04P4L-08     OptiMOS      LL      -40        7.8        -70     TO252-3.(DPAK)     IPD70P04P4L_08     IPD70P04P4L_08_L1    IPD70P04P4L_08_L0   
* IPD85P04P4L-06     OptiMOS      LL      -40        6.4        -85     TO252-3.(DPAK)     IPD85P04P4L_06     IPD85P04P4L_06_L1    IPD85P04P4L_06_L0   
* IPD90P04P4L-04     OptiMOS      LL      -40        4.3        -90     TO252-3.(DPAK)     IPD90P04P4L_04     IPD90P04P4L_04_L1    IPD90P04P4L_04_L0   
* IPB120P04P4-04     OptiMOS      NL      -40        3.6       -120     TO263-3.(D2PAK)    IPB120P04P4_04     IPB120P04P4_04_L1    IPB120P04P4_04_L0   
* IPB180P04P4-03     OptiMOS      NL      -40        2.8       -180     TO263-7.(D2PAK)    IPB180P04P4_03     IPB180P04P4_03_L1    IPB180P04P4_03_L0   
* IPB70P04P4-09      OptiMOS      NL      -40        9.1        -70     TO263-3.(D2PAK)    IPB70P04P4_09      IPB70P04P4_09_L1     IPB70P04P4_09_L0    
* IPB80P04P4-05      OptiMOS      NL      -40        4.9        -80     TO263-3.(D2PAK)    IPB80P04P4_05      IPB80P04P4_05_L1     IPB80P04P4_05_L0    
* IPB80P04P4-07      OptiMOS      NL      -40        7.3        -80     TO263-3.(D2PAK)    IPB80P04P4_07      IPB80P04P4_07_L1     IPB80P04P4_07_L0    
* IPD50P04P4-13      OptiMOS      NL      -40       12.6        -50     TO252-3.(DPAK)     IPD50P04P4_13      IPD50P04P4_13_L1     IPD50P04P4_13_L0    
* IPD70P04P4-09      OptiMOS      NL      -40        8.9        -70     TO252-3.(DPAK)     IPD70P04P4_09      IPD70P04P4_09_L1     IPD70P04P4_09_L0    
* IPD85P04P4-07      OptiMOS      NL      -40        7.3        -85     TO252-3.(DPAK)     IPD85P04P4_07      IPD85P04P4_07_L1     IPD85P04P4_07_L0    
* IPD90P04P4-05      OptiMOS      NL      -40        4.7        -90     TO252-3.(DPAK)     IPD90P04P4_05      IPD90P04P4_05_L1     IPD90P04P4_05_L0      
* 
* ------------------------------------------------------------------------------
* 
* Thermal nodes of level 3 models: 
* 
*  Tj:    Potential (temperature in °C) at junction (typically not connected) 
*  Tcase: Node where boundary condition (external heat sinks) must be connected.
*         Ideal heat sink can be modeled by using a voltage source stating the 
*         ambient temperature in °C between Tcase and ground. 
* 
* ------------------------------------------------------------------------------
* 
* This file also contains simplified models that are compatible to standard 
* Spice (Level 0) 
* 
* ------------------------------------------------------------------------------
* 
* History: 
* DD/MM/YY 
* xx/xx/10 initial version                                             (Nöbauer)
* 02/02/11 new models for:                                      (Gondro, Moyses)
*            IPB180P04P4-03          IPB120P04P4L-03           
*            IPB120P04P4-04          IPB80P04P4L-04            
*            IPB80P04P4-05           IPD90P04P4L-04            
*            IPD90P04P4-05           IPB80P04P4L-06            
*            IPI80P04P4-05           IPD85P04P4L-06            
*            IPP80P04P4-05           IPB70P04P4L-08            
*            IPB80P04P4-07           IPD70P04P4L-08            
*            IPD85P04P4-07                                     
*            IPB70P04P4-09                                     
*            IPD70P04P4-09                                     
*            IPI70P04P4-09                                     
*            IPP70P04P4-09                                     
*            IPD50P04P4-13                                     
* 20/04/11 renamed model IPB70P04P4L-08 to IPB80P04P4L-08       (Gondro, Moyses)
* 17/05/17 rename Zthtype -> dZth                               (Gondro, Moyses)
* 03/05/18 param Rlim limited to avoid negative sqrt                    (Gondro)
* 25/01/19 fixed bug in .FUNC Pb(I,dT,Rb)                               (Gondro)
* 19/03/19 lambda set to 1m in L0                                       (Gondro)
*          W=L=10u in sw (L0), as default SPICE2 is 1m
*          introduced LAMBDA, CGDO, CGSO, CGBO for better convergence
*          IS set to 0 in mos1/3 (avoiding drain-bulk forward direction)
*          removed Rpar[2] in level0 avoiding negative drain current
*          par GSshort introduced
* 20/03/19 subcircuit P4_40_r_var (PFET4-40V LL) removed                (Gondro)
*          all products shifted to P4_40_r1_var (PFET4-40V LL ATV)
* 08/09/22 added Compact Model Completion Monitor                       (Gondro)
*          model lib reduced to products with status "active and preferred"
* 21/12/22 Vth shift corrected                                            (Koch)
* 
* ------------------------------------------------------------------------------
* 
* P4_40_s_var:  PFET4-40V NL
* P4_40_r1_var: PFET4-40V LL ATV
* 
* ------------------------------------------------------------------------------

* LTspice: turning off default 1 mOhm series damping resistance (R=0)
.options Thev_Induc=1

********************************************************************************
* Technology Models
********************************************************************************

.SUBCKT P4_40_s_var dd g s0 Tj PARAMS: a=1 dVth=0 dR=0 dgfs=0 Inn=1 Unn=1 Rmax=1
+ gmin=1 Rs=1 Rp=50u dC=0 Rm=1u

.PARAM  Fm=0.35452   Fn=0.60929  al=1.0
.PARAM  c=1.24       Vth0=4.29   auth=3.33m
.PARAM  dvx=550m     dvgs=170m   auth_sub=2.47m
.PARAM  UT=100m      ab=11m      lB=-23       UB=46.7

.PARAM  b0=29.55     p0=6.45     p1=-23.0m    p2=49u

.PARAM  Rd=15.0m     nmu=1.94    Tref=298     T0=273      lnIsj=-26.12
.PARAM  ndi=1.15     n_Isj=1.0   Rdi=6.0m     nmu2=0.3
.PARAM  ta=30n       td=30n
.PARAM  Rf=0.40817   nmu3=0.6889

.PARAM  f1=394p      f2=652p     f3=927.13p   U0=18.17    nc=3.1     nd=0.954
.PARAM  g1=0.08322   bb=3.51     remp=0.01p   f2r=275p
.PARAM  kbq=86.2u

.PARAM  Vmin=3.29    Vmax=5.29   dCmax=0.33
.PARAM  Vth={Vth0+(Vmax-Vth0)*limit(dVth,0,1)-(Vmin-Vth0)*limit(dVth,-1,0)}
.PARAM  q0={b0*((T0/Tref)**nmu3)*a}
.PARAM  q1={(Unn-Inn*Rs-Vth0)*q0}
.PARAM  q2={(Fm*sqrt(0.4)-c)*Inn*q0}
.PARAM  Rlim={(q1+2*q2*Rmax-sqrt(max(q1**2+4*q2,0)))/(2*q2)}
.PARAM  dRd={Rd/a+if(dVth==0,limit(dR,0,1)*max(Rlim-Rd/a-Rs-Rp,0),0)}
.PARAM  bm={c/((1/gmin-Rs)**2*Inn*a*(T0/Tref)**nmu3)}
.PARAM  bet={b0+(b0-bm)*if(dR==0,if(dVth==0,limit(dgfs,-1,0),0),0)}
.PARAM  dC1={1+dCmax*limit(dC,0,1)}
.PARAM  dC2={1+1.5*dCmax*limit(dC,0,1)}

.PARAM  Cox={f1*a*dC2}
.PARAM  Cox1={remp*sqrt(a)*dC2}
.PARAM  Cds0={(f2*a+f2r*sqrt(a))*dC1}
.PARAM  Cgs0={f3*a*dC1}
.PARAM  dRdi={Rdi/a}

.FUNC  Ue(g,y,w)          {(g-Vth+auth*(w-Tref)+Fm*y**Fn)}
.FUNC  Ue1(g,y,w)         {Ue(g,y,w)+(1+limit(Ue(g,y,w)+dvx,0,1)**2*(2*limit(Ue(g,y,w)+dvx,0,1)-3))*(dvgs+(auth_sub-auth)*(w-Tref))}

.FUNC  Ia(Uee,p,pp,z1)    {if(Uee>pp,(Uee-c*z1)*z1,p*(pp-p)/c*exp((Uee-pp)/p))}
.FUNC  Ih(Uds,T,p,Uee)    {bet*(T0/T)**nmu3*Ia(Uee,p,min(2*p,p+c*Uds),min(Uds,Uee/(2*c)))}
.FUNC  Jh(d,g,w,y,s)      {a*((Ih(s*y+min(d,0),w,(p0+(p1+p2*w)*w)*kbq*w,Ue1(g,y,w))+exp(min(lB+(d-UB-ab*(w-Tref))/UT,24))))}

.FUNC  Idiode(Usd,Tj,Iss) {exp(min(log(Iss)+Usd/(ndi*kbq*Tj),7))-Iss}
.FUNC  Idiod(Usd,Tj)      {a*Idiode(Usd,Tj,exp(min(lnIsj+(Tj/Tref-1)*1.12/(ndi*kbq*Tj),7))*(Tj/Tref)**n_Isj)}

E_Edg     d   ox  VALUE   {-(max(V(g,d),-bb)-(1/(g1*(1-nc))*((1/(1+g1*max(V(g,d)+(bb),0)))**(nc-1)-(1/(1+g1*bb))**(nc-1))))}
C_Cdg    ox    g  {Cox}
V_x       d   ox1 0
C_Cdg1   ox1   g  {Cox1}

E_Eds    d edep   VALUE {-((V(s,d)-I(V_sense3)/Cds0))}
C_Cds  edep    s  {Cds0}

C_Cgs    g    s   {Cgs0}

G_chan    d    s  VALUE={-Jh(V(s,d),V(s,g),T0+limit(V(Tj),-200,300),(sqrt(1+4*al*abs(V(s,d)))-1)/2/al,sgn(V(s,d)))}

G_RMos   d1    d  VALUE={V(d1,d)/(Rf*dRd+(1-Rf)*dRd*((limit(V(Tj),-200,999)+T0)/Tref)**nmu)}
V_sense  dd   d1  0

G_diode   s   d3  VALUE={-Idiod(V(d3,s),T0+limit(V(Tj),-200,499))}
G_Rdio   d2   d1  VALUE={V(d2,d1)/(dRdi*((limit(V(Tj),-200,999)+T0)/Tref)**nmu2)}
V_sense2 d2   d3  0

L_L001    a    c  {td/(ta+td)}
R_R001    a    b  {1/ta}
V_sense3  c    0  0
E_E001    b    0  VALUE {-I(V_sense2)}
E_E002    e    0  VALUE {Cds0*1/(1-nd)*U0**nd*(limit(U0+V(s,d1),0,2*UB))**(1-nd)}
R_R002    e    c  1
R_R003    a    0  500Meg

R_1       g    s  1G
R_d01     d    s  500Meg
R_d02    d2    s  500Meg
R_d03    d1    d  1k

R_met     s    s0 {Rm}

G_th      0   Tj  VALUE={(limit(I(V_sense2)*V(d1,s)+(V(s,s0)**2)/Rm+(I(V_sense)-I(V_sense2))*V(d1,d)+
+ (I(V_sense)-I(V_sense2)-I(E_Edg)-I(V_x)-I(E_Eds))*V(d,s),-10k,100k))}

.ENDS


************************


.SUBCKT P4_40_r1_var dd g s0 Tj PARAMS: a=1 dVth=0 dR=0 dgfs=0 Inn=1 Unn=1 Rmax=1
+ gmin=1 Rs=1 Rp=50u dC=0 Rm=1u

.PARAM  Fm=0.09404   Fn=0.85912  al=1.0
.PARAM  c=0.89402    Vth0=2.63   auth=2.479m
.PARAM  dvx=550m     dvgs=290m   auth_sub=1.21m
.PARAM  UT=100m      ab=11m      lB=-23       UB=46.4

.PARAM  b0=45.83     p0=5.06     p1=-17.7m    p2=34u

.PARAM  Rd=18.6m     nmu=1.51    Tref=298     T0=273      lnIsj=-25.71
.PARAM  ndi=1.12     n_Isj=1.0   Rdi=5.98m    nmu2=0.294
.PARAM  ta=30n       td=30n
.PARAM  Rf=0.45234   nmu3=0.9997

.PARAM  f1=320p      f2=800p     f3=1.05n     U0=15       nc=2.5      nd=0.95
.PARAM  g1=0.12      bb=4        remp=0.01p   f2r=230p
.PARAM  kbq=86.2u

.PARAM  Vmin=2.13    Vmax=3.13   dCmax=0.33
.PARAM  Vth={Vth0+(Vmax-Vth0)*limit(dVth,0,1)-(Vmin-Vth0)*limit(dVth,-1,0)}
.PARAM  q0={b0*((T0/Tref)**nmu3)*a}
.PARAM  q1={(Unn-Inn*Rs-Vth0)*q0}
.PARAM  q2={(Fm*sqrt(0.4)-c)*Inn*q0}
.PARAM  Rlim={(q1+2*q2*Rmax-sqrt(max(q1**2+4*q2,0)))/(2*q2)}
.PARAM  dRd={Rd/a+if(dVth==0,limit(dR,0,1)*max(Rlim-Rd/a-Rs-Rp,0),0)}
.PARAM  bm={c/((1/gmin-Rs)**2*Inn*a*(T0/Tref)**nmu3)}
.PARAM  bet={b0+(b0-bm)*if(dR==0,if(dVth==0,limit(dgfs,-1,0),0),0)}
.PARAM  dC1={1+dCmax*limit(dC,0,1)}
.PARAM  dC2={1+1.5*dCmax*limit(dC,0,1)}

.PARAM  Cox={f1*a*dC2}
.PARAM  Cox1={remp*sqrt(a)*dC2}
.PARAM  Cds0={(f2*a+f2r*sqrt(a))*dC1}
.PARAM  Cgs0={f3*a*dC1}
.PARAM  dRdi={Rdi/a}

.FUNC  Ue(g,y,w)          {(g-Vth+auth*(w-Tref)+Fm*y**Fn)}
.FUNC  Ue1(g,y,w)         {Ue(g,y,w)+(1+limit(Ue(g,y,w)+dvx,0,1)**2*(2*limit(Ue(g,y,w)+dvx,0,1)-3))*(dvgs+(auth_sub-auth)*(w-Tref))}

.FUNC  Ia(Uee,p,pp,z1)    {if(Uee>pp,(Uee-c*z1)*z1,p*(pp-p)/c*exp((Uee-pp)/p))}
.FUNC  Ih(Uds,T,p,Uee)    {bet*(T0/T)**nmu3*Ia(Uee,p,min(2*p,p+c*Uds),min(Uds,Uee/(2*c)))}
.FUNC  Jh(d,g,w,y,s)      {a*((Ih(s*y+min(d,0),w,(p0+(p1+p2*w)*w)*kbq*w,Ue1(g,y,w))+exp(min(lB+(d-UB-ab*(w-Tref))/UT,24))))}

.FUNC  Idiode(Usd,Tj,Iss) {exp(min(log(Iss)+Usd/(ndi*kbq*Tj),7))-Iss}
.FUNC  Idiod(Usd,Tj)      {a*Idiode(Usd,Tj,exp(min(lnIsj+(Tj/Tref-1)*1.12/(ndi*kbq*Tj),7))*(Tj/Tref)**n_Isj)}

E_Edg     d   ox  VALUE {-(max(V(g,d),-bb)-(1/(g1*(1-nc))*((1/(1+g1*max(V(g,d)+(bb),0)))**(nc-1)-(1/(1+g1*bb))**(nc-1))))}
C_Cdg    ox    g  {Cox}
V_x       d   ox1 0
C_Cdg1   ox1   g  {Cox1}


E_Eds    d edep  VALUE {-((V(s,d)-I(V_sense3)/Cds0))}
C_Cds  edep    s  {Cds0}

C_Cgs    g    s   {Cgs0}

G_chan    d    s  VALUE={-Jh(V(s,d),V(s,g),T0+limit(V(Tj),-200,300),(sqrt(1+4*al*abs(V(s,d)))-1)/2/al,sgn(V(s,d)))}

G_RMos   d1    d  VALUE={V(d1,d)/(Rf*dRd+(1-Rf)*dRd*((limit(V(Tj),-200,999)+T0)/Tref)**nmu)}
V_sense  dd   d1  0

G_diode   s   d3  VALUE={-Idiod(V(d3,s),T0+limit(V(Tj),-200,499))}

G_Rdio   d2   d1  VALUE={V(d2,d1)/(dRdi*((limit(V(Tj),-200,999)+T0)/Tref)**nmu2)}
V_sense2 d2   d3  0

L_L001    a    c  {td/(ta+td)}
R_R001    a    b  {1/ta}
V_sense3  c    0  0
E_E001    b    0  VALUE {-I(V_sense2)}
E_E002    e    0  VALUE {Cds0*1/(1-nd)*U0**nd*(limit(U0+V(s,d1),0,2*UB))**(1-nd)}
R_R002    e    c  1
R_R003    a    0  500Meg

R_1       g    s  1G
R_d01     d    s  500Meg
R_d02    d2    s  500Meg
R_d03    d1    d  1k

